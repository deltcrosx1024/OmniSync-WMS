# MongoDB connection
# If you prefer using public/private key auth instead of a full URI, define MONGODB_HOST and the API keys below.
MONGODB_HOST=cluster.example.mongodb.net
MONGODB_API_PUB_KEY=<public_key>
MONGODB_API_PRIV_KEY=<private_key>
# Optional app name for the MongoDB client connection
MONGODB_APP_NAME=OmniSync

# Alternatively, use a full MongoDB URI:
# MONGODB_URI=mongodb+srv://<user>:<password>@cluster.example.mongodb.net/gridflow

# JWT secret used by API authentication
JWT_SECRET=replace-with-a-long-secret

# Superadmin bootstrap credentials (fall back if there are no users)
SUPERADMIN_EMAIL=admin@gridflow.local
SUPERADMIN_PASSWORD=Admin@123
SUPERADMIN_PIN=0000
SUPERADMIN_NAME=Super Administrator

# Loyverse API credentials for inventory sync
LOYVERSE_CLIENT_ID=
LOYVERSE_CLIENT_SECRET=
LOYVERSE_TOKEN_URL=https://api.loyverse.com/oauth/token
LOYVERSE_API_BASE_URL=https://api.loyverse.com
# Redirect URI registered in Loyverse OAuth settings
LOYVERSE_REDIRECT_URI=https://omnisync.vercel.app/api/callback
